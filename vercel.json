{
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": true,
  "redirects": [
    {"source": "/catalog", "destination": "/invoice-generator/catalog.html", "permanent": false},
    {"source": "/invoices", "destination": "/invoice-generator/catalog.html", "permanent": false},
    {"source": "/new", "destination": "/invoice-generator/", "permanent": false},
    {"source": "/generator", "destination": "/invoice-generator/", "permanent": false}
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
      ]
    }
  ]
}
